    Both { $var1 } and { $var2 } have read the same amount of chapters
anilist_user_compare-same_tag_anime =
    Both { $var1 } and { $var2 } prefer the { $var1a } tag for anime
anilist_user_compare-same_tag_manga =
    Both { $var1 } and { $var2 } prefer the { $var1a } tag for manga
anilist_user_compare-same_watch_time =
    Both { $var1 } and { $var2 } have watched anime for the same amount of time
anilist_user_compare-tag_anime =
    { $var1 } prefers the { $var1a } tag, and { $var2 } prefers the { $var2a } tag for anime
