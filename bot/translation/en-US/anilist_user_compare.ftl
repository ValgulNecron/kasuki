anilist_user_compare-affinity =
    Affinity between { $var1 } and { $var2 } is { $var3 }
anilist_user_compare-genre_anime =
    { $var1 } prefers the { $var1a } genre, and { $var2 } prefers the { $var2a } genre for anime
anilist_user_compare-genre_manga =
    { $var1 } prefers the { $var1a } genre, and { $var2 } prefers the { $var2a } genre for manga
anilist_user_compare-more_anime =
    { $greater } as watched more anime than { $lesser }
anilist_user_compare-more_manga =
    { $greater } as read more manga than { $lesser }
anilist_user_compare-more_manga_chapter =
    { $greater } as read more chapters than { $lesser }
anilist_user_compare-more_watch_time =
    { $greater } as more watch time than { $lesser }
anilist_user_compare-same_anime =
    Both { $var1 } and { $var2 } have watched the same amount of anime
anilist_user_compare-same_genre_anime =
    Both { $var1 } and { $var2 } prefer the { $var1a } genre for anime
anilist_user_compare-same_genre_manga =
